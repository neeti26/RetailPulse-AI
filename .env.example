# ============================================================
# RetailPulse AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ------------------------------------------------------------
# MongoDB Configuration (REQUIRED)
# ------------------------------------------------------------
# Use MongoDB Atlas (recommended) or local MongoDB
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/retailpulse
# Local: mongodb://localhost:27017/retailpulse
MONGODB_URI=mongodb://localhost:27017/retailpulse

# Database name
MONGODB_DB_NAME=retailpulse

# ------------------------------------------------------------
# Google AI / Gemini (REQUIRED — choose one)
# ------------------------------------------------------------
# Option A: Gemini API Key (simplest for local dev)
GOOGLE_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI (for production / Google Cloud deployment)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ------------------------------------------------------------
# MongoDB Atlas API Credentials (OPTIONAL)
# Required only for Atlas management tools (cluster creation,
# performance advisor, access list management, etc.)
# ------------------------------------------------------------
# MDB_ATLAS_CLIENT_ID=your_atlas_service_account_client_id
# MDB_ATLAS_CLIENT_SECRET=your_atlas_service_account_client_secret

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
# Mall name shown in the UI
MALL_NAME=Sunrise Mall

# Agent model (gemini-2.5-flash recommended for speed+quality)
AGENT_MODEL=gemini-2.5-flash

# Anomaly detection threshold (percentage drop that triggers alert)
ANOMALY_THRESHOLD_PCT=20

# Web UI port
UI_PORT=7860

# Enable debug logging (true/false)
DEBUG=false
